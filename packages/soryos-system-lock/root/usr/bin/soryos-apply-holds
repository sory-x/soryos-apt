#!/usr/bin/env bash
set -euo pipefail

PACKAGES=(
  pop-desktop
  ubuntu-desktop
  gnome-shell
)

if [[ "${EUID}" -ne 0 ]]; then
  printf 'run as root: sudo %s\n' "$0" >&2
  exit 1
fi

for package in "${PACKAGES[@]}"; do
  if dpkg-query -W -f='${Status}' "$package" 2>/dev/null | grep -q 'install ok installed'; then
    apt-mark hold "$package"
  else
    printf 'skip hold, not installed: %s\n' "$package"
  fi
done

dpkg-query -W -f='${binary:Package}\n' 'system76-*' 2>/dev/null | while read -r package; do
  if [[ -n "$package" ]]; then
    apt-mark hold "$package"
  fi
done

printf 'SoryOS stability holds applied.\n'
printf 'Rollback: sudo soryos-remove-holds\n'
