#!/usr/bin/env bash
set -euo pipefail

MODE="desktop"
DRY_RUN=0
CHANNEL="stable"
LOG_DIR="${SORYOS_LOG_DIR:-/var/log/soryos}"

usage() {
  cat <<'EOF'
usage: soryos-install [--base|--desktop|--full] [--dry-run] [--channel stable|testing|nightly]

Modes:
  --base       Install base SoryOS desktop modules
  --desktop    Install soryos-desktop metapackage (default)
  --full       Install the current full progressive SoryOS layer

Safety:
  --dry-run    Simulate only
  All modes refuse removals, purges, autoremoves, conflicts, and protected
  system package replacements before applying changes.

This command does not remove Pop!_OS repositories.
EOF
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --base)
      MODE="base"
      ;;
    --desktop)
      MODE="desktop"
      ;;
    --full)
      MODE="full"
      ;;
    --dry-run)
      DRY_RUN=1
      ;;
    --channel)
      CHANNEL="${2:-}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

case "$CHANNEL" in
  stable|testing|nightly) ;;
  *)
    printf 'invalid channel: %s\n' "$CHANNEL" >&2
    exit 2
    ;;
esac

if [[ "${EUID}" -ne 0 ]]; then
  printf 'run as root: sudo %s\n' "$0" >&2
  exit 1
fi

case "$MODE" in
  base)
    PACKAGES=(soryos-archive-keyring soryos-system-lock sory-shell sory-theme sory-settings sory-installer)
    ;;
  desktop)
    PACKAGES=(soryos-desktop)
    ;;
  full)
    PACKAGES=(soryos-desktop soryos-system-lock sory-installer)
    ;;
esac

mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/soryos-install.log"

{
  printf 'SoryOS installer\n'
  printf 'Channel: %s\n' "$CHANNEL"
  printf 'Mode: %s\n' "$MODE"
  printf 'Will install: %s\n' "${PACKAGES[*]}"
  printf 'Will keep: Pop!_OS repositories, Ubuntu fallback, kernel, initramfs, boot stack, drivers, pop-desktop\n'
  printf 'Will refuse: remove, purge, critical autoremove, conflicts, protected system package replacement\n'
} | tee "$LOG_FILE"

if [[ ! -x /usr/lib/soryos/apt-safe-install ]]; then
  printf 'missing required helper: /usr/lib/soryos/apt-safe-install\n' | tee -a "$LOG_FILE" >&2
  exit 1
fi

if [[ "$DRY_RUN" -eq 1 ]]; then
  SORYOS_APT_SAFE_LOG="$LOG_DIR/soryos-install-apt-simulation.log" \
    /usr/lib/soryos/apt-safe-install --dry-run --install "${PACKAGES[@]}" | tee -a "$LOG_FILE"
  exit 0
fi

SORYOS_APT_SAFE_LOG="$LOG_DIR/soryos-install-apt-apply.log" \
  /usr/lib/soryos/apt-safe-install --install "${PACKAGES[@]}" | tee -a "$LOG_FILE"

printf 'SoryOS installation stage complete. Logs: %s\n' "$LOG_DIR" | tee -a "$LOG_FILE"
