#!/usr/bin/env bash
set -euo pipefail

MODE="desktop"
DRY_RUN=0
CHANNEL="stable"
NO_REMOVE=1

usage() {
  cat <<'EOF'
usage: soryos-install [--base|--desktop] [--dry-run] [--channel stable|testing|nightly] [--no-remove]

Modes:
  --base       Install base SoryOS desktop modules
  --desktop    Install soryos-desktop metapackage (default)

Safety:
  --dry-run    Simulate only
  --no-remove  Refuse removals (default)

This command does not remove Pop!_OS repositories.
EOF
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --base)
      MODE="base"
      ;;
    --desktop)
      MODE="desktop"
      ;;
    --dry-run)
      DRY_RUN=1
      ;;
    --channel)
      CHANNEL="${2:-}"
      shift
      ;;
    --no-remove)
      NO_REMOVE=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

case "$CHANNEL" in
  stable|testing|nightly) ;;
  *)
    printf 'invalid channel: %s\n' "$CHANNEL" >&2
    exit 2
    ;;
esac

if [[ "${EUID}" -ne 0 ]]; then
  printf 'run as root: sudo %s\n' "$0" >&2
  exit 1
fi

case "$MODE" in
  base)
    PACKAGES=(soryos-archive-keyring soryos-system-lock sory-shell sory-theme sory-settings sory-installer)
    ;;
  desktop)
    PACKAGES=(soryos-desktop)
    ;;
esac

printf 'SoryOS installer\n'
printf 'Channel: %s\n' "$CHANNEL"
printf 'Mode: %s\n' "$MODE"
printf 'Packages: %s\n' "${PACKAGES[*]}"

apt-get update

if [[ "$DRY_RUN" -eq 1 ]]; then
  apt-get -s install "${PACKAGES[@]}"
  exit 0
fi

if [[ "$NO_REMOVE" -eq 1 && -x /usr/lib/soryos/apt-safe-install ]]; then
  /usr/lib/soryos/apt-safe-install "${PACKAGES[@]}"
else
  apt-get install -y "${PACKAGES[@]}"
fi

printf 'SoryOS installation stage complete.\n'
